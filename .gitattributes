# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto

# Force Unix newlines
**/bin/** text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.example text eol=lf
Dockerfile text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.svg text eol=lf
*.sql text eol=lf
*.rs text eol=lf
.gitignore text eol=lf
.giattributes text eol=lf
.babelrc text eol=lf

# Hide diff for certain heavy files by default in Github pull request
system-tests/src/__screenshots__/**/*.png linguist-generated=true
system-tests/src/__screenshots__/**/*.png filter=lfs diff=lfs merge=lfs -text
services/headless-lms/models/.sqlx/**/*.json linguist-generated=true

# Certificate fonts (seeded into local/test/dev). Compiled in via include_bytes!, so builds must
# have git-lfs hydrated before `cargo build`, or embedded fonts become pointer text.
services/headless-lms/server/src/programs/seed/data/*.ttf filter=lfs diff=lfs merge=lfs -text
services/headless-lms/server/src/programs/seed/data/*.otf filter=lfs diff=lfs merge=lfs -text
