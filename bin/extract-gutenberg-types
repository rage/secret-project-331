#!/bin/bash
set -euo pipefail
source "$(dirname "$0")/.common"

BASEDIR="$(dirname "${BASH_SOURCE[0]}")"

CMS_PATH="$BASEDIR/../services/cms/"

RELATIVE_CMS_PATH=$(realpath --relative-to="$(pwd)" "$CMS_PATH")

run_command cd "$RELATIVE_CMS_PATH" || exit

# Register a custom Node ESM resolver hook to work around
# @wordpress/block-editor importing "diff/lib/diff/character" without a .js
# suffix (diff@9's package exports only define "./lib/*.js" subpaths, so strict
# Node ESM would otherwise fail with ERR_PACKAGE_PATH_NOT_EXPORTED).
# Keep NODE_OPTIONS off pnpm itself; pnpm 11 validates workspace config before
# exec and will try to load pnpm hooks during startup if the hook is inherited.
HOOK_IMPORT="./scripts/registerDiffResolveHook.mjs"
run_command pnpm exec env NODE_OPTIONS="${NODE_OPTIONS:-} --import $HOOK_IMPORT" tsx scripts/extractGutenbergAttributeTypes.ts

# Format the generated files with oxfmt
run_command pnpm exec oxfmt ../main-frontend/types/GutenbergBlockAttributes.ts ../main-frontend/types/DeprecatedGutenbergBlockAttributes.ts

run_command cd ../..
if [ -f "./services/main-frontend/types/GutenbergBlockAttributes.guard.ts" ]; then
  run_command rm ./services/main-frontend/types/GutenbergBlockAttributes.guard.ts
fi
if [ -f "./services/main-frontend/types/DeprecatedGutenbergBlockAttributes.guard.ts" ]; then
  run_command rm ./services/main-frontend/types/DeprecatedGutenbergBlockAttributes.guard.ts
fi

# Only the source type file is formatted; guard files are committed as ts-auto-guard emits them
# (they are excluded from oxfmt, so passing them here would be a no-op at best).
run_command pnpm exec ts-auto-guard --export-all --paths services/main-frontend/types/GutenbergBlockAttributes.ts --project services/main-frontend/tsconfig.json
run_command pnpm exec oxfmt services/main-frontend/types/GutenbergBlockAttributes.ts

run_command pnpm exec ts-auto-guard --export-all --paths services/main-frontend/types/DeprecatedGutenbergBlockAttributes.ts --project services/main-frontend/tsconfig.json
run_command pnpm exec oxfmt services/main-frontend/types/DeprecatedGutenbergBlockAttributes.ts
