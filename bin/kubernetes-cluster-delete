#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
source "${SCRIPT_DIR}/.common"

REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
CTLPTL_CONFIG="${REPO_ROOT}/config/kind-cluster.ctlptl.yaml"

disallow_running_as_root
ensure_program_in_path "ctlptl"

run_command ctlptl delete -f "$CTLPTL_CONFIG" "$@"
