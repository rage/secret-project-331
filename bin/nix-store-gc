#!/bin/bash
set -euo pipefail
source "$(dirname "$0")/.common"

# Reclaim disk space by deleting unreferenced Nix store paths. Anything still in
# use (GC roots, active profiles) is kept, and deleted paths are re-fetched
# deterministically from flake.lock the next time you enter the dev shell.

ensure_program_in_path "nix"

echo -e "${BLUE}Disk usage before:${RESET_EVERYTHING}"
run_command df -h /nix/store

run_command nix store gc "$@"

echo -e "${GREEN}Disk usage after:${RESET_EVERYTHING}"
run_command df -h /nix/store
