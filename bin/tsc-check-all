#!/bin/bash
set -euo pipefail
source "$(dirname "$0")/.common"

run_command pnpm exec concurrently \
  -n "cms,main-frontend,example-exercise,quizzes,tmc,exercise-protocol,exercise-client,exercise-react,create-exercise-service" \
  -c "green.bold,red.bold,blue.bold,yellow.bold,cyan.bold,magenta.bold,white.bold,gray.bold,greenBright.bold" \
  "cd services/cms && pnpm exec tsc --noEmit" \
  "cd services/main-frontend && pnpm exec tsc --noEmit" \
  "cd services/example-exercise && pnpm exec tsc --noEmit" \
  "cd services/quizzes && pnpm exec tsc --noEmit" \
  "cd services/tmc && pnpm exec tsc --noEmit" \
  "cd shared-module/packages/exercise-protocol && pnpm exec tsc --noEmit" \
  "cd shared-module/packages/exercise-client && pnpm exec tsc --noEmit" \
  "cd shared-module/packages/exercise-react && pnpm exec tsc --noEmit" \
  "cd shared-module/packages/create-exercise-service && pnpm exec tsc --noEmit"

echo "finished"
