{
  "name": "secret-project-331",
  "version": "0.0.0",
  "description": "",
  "homepage": "https://github.com/rage/secret-project-331#readme",
  "main": "index.js",
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "bugs": {
    "url": "https://github.com/rage/secret-project-331/issues"
  },
  "pnpm": {
    "overrides": {
      "eslint-plugin-jsx-a11y>minimatch": "3.1.2"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rage/secret-project-331.git"
  },
  "scripts": {
    "codegen:openapi-ts": "bash -lc 'echo \"ERROR: The only correct way to regenerate OpenAPI TS clients is to run the bin/generate-bindings command.\"; exit 1'",
    "eslint": "eslint --fix .",
    "eslint:ci": "eslint .",
    "eslint:format-bindings": "eslint --fix shared-module/packages/common/src/bindings.ts",
    "eslint:format-generated-docs": "prettier --write services/headless-lms/server/generated-docs/",
    "eslint:open:vscode": "eslint . --format json | jq '(.[] | select((.errorCount > 0) or (.warningCount > 0))).filePath' | xargs code",
    "export-openapi": "bash -lc 'echo \"ERROR: The only correct way to regenerate OpenAPI specs is to run the bin/generate-bindings command.\"; exit 1'",
    "lint:css": "stylelint '**/*.tsx'",
    "lint:no-inline-api-paths": "bash -lc \"! rg -n '(/api/v0/|/api/ws/)' services/cms/src services/main-frontend/src --glob '!**/generated/**' --glob '!**/services/mediaUpload.ts' --glob '!**/hooks/playground/usePlaygroundQueriesAndMutations.tsx' --glob '!**/app/playground-views/page.tsx' --glob '!**/app/playground-views/PlaygroundPreview.tsx' --glob '!**/certificates/CertificateView.tsx' --glob '!**/tabs/CertificatesTab.tsx' --glob '!**/components/course-material/chatbot/shared/hooks/useChatbotStateAndData.ts'\"",
    "postinstall": "cd shared-module && pnpm install && pnpm run sync-once",
    "prepare": "husky"
  },
  "dependencies": {
    "@vectopus/atlas-icons": "^0.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@hey-api/openapi-ts": "0.95.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@stylelint/postcss-css-in-js": "^0.38.0",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-explicit-use-directives": "^0.0.3",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.17",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "postcss": "^8.5.6",
    "postcss-styled-syntax": "^0.7.1",
    "postcss-syntax": "^0.36.2",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended": "^18.0.0",
    "ts-auto-guard": "^5.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
