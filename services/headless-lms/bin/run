#!/bin/bash
set -euo pipefail

BASEDIR="$(dirname "${BASH_SOURCE[0]}")"
FOLDER_PATH="$BASEDIR/.."
ABSOLUTE_PATH=$(realpath "$FOLDER_PATH")

# Cd to the root of the headless-lms folder
echo "\$ cd $ABSOLUTE_PATH"
cd "$ABSOLUTE_PATH" || exit


if [ "$#" -eq 0 ]; then
  echo "Error: Please give the program name as an argument e.g. \"bin/run start-server\""
  exit 1
fi

if [ -f "headless-lms-entrypoint" ]; then
  # This happens in production and in bin/test
  echo "\$ ./headless-lms-entrypoint $*"
  exec ./headless-lms-entrypoint "$*"
else
  # This happens in bin/dev
  # Note: intentionally no --package: a package-scoped build resolves features
  # differently than the workspace-scoped `cargo build` baked into the dev image,
  # which would force every pod to recompile the server crates on startup.
  # A plain `cargo run` reuses the image's build (headless-lms-entrypoint is the
  # only binary in the workspace, so the target is unambiguous).
  echo "\$ cargo run -- $*"
  exec cargo run -- "$*"
fi
