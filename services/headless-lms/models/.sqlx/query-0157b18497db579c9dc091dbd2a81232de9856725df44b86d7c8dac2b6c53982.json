  "query": "\nSELECT p.id,\n  p.created_at,\n  p.updated_at,\n  p.course_id,\n  p.exam_id,\n  p.chapter_id,\n  p.url_path,\n  p.title,\n  p.deleted_at,\n  p.content,\n  p.order_number,\n  p.copied_from,\n  p.hidden,\n  p.page_language_group_id\nFROM chapters c\n  JOIN pages p ON p.id = c.front_page_id\nWHERE c.id = $1\n  AND c.deleted_at IS NULL\n  AND p.deleted_at IS NULL\n        ",
