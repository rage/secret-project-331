  "query": "\nSELECT c.id,\n  c.name,\n  c.created_at,\n  c.updated_at,\n  c.organization_id,\n  c.description, cm.uh_course_code\nFROM courses as c LEFT JOIN course_modules as cm on c.id = cm.course_id\nWHERE c.deleted_at IS NULL AND cm.deleted_at is NULL AND order_number = 0;\n",
