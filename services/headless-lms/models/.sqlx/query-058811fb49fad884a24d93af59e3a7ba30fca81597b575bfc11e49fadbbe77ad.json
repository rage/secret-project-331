  "query": "\nSELECT\n    id,\n    service,\n    exact_error_identifier,\n    error_grouping_identifier,\n    error_source AS \"error_source: ErrorSource\",\n    example_message,\n    example_stack_trace,\n    normalized_message,\n    normalized_stack_trace,\n    occurrence_count,\n    last_seen_at,\n    resolved_at,\n    created_at,\n    updated_at,\n    deleted_at\nFROM error_variants\nWHERE deleted_at IS NULL\nORDER BY last_seen_at DESC\nLIMIT $1 OFFSET $2\n        ",
