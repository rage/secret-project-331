  "query": "\n    SELECT DISTINCT ON (user_id)\n        id,\n        created_at,\n        updated_at,\n        deleted_at,\n        exercise_slide_id,\n        course_id,\n        exam_id,\n        exercise_id,\n        user_id,\n        user_points_update_strategy,\n  flag_count\nFROM exercise_slide_submissions\nWHERE exercise_id = $1\n      AND deleted_at IS NULL\nORDER BY user_id, created_at DESC\nLIMIT $2 OFFSET $3\n        ",
