  "query": "\n    INSERT INTO suspected_cheaters (\n      user_id,\n      total_duration_seconds,\n      total_points,\n      course_id\n    )\n    VALUES ($1, $2, $3, $4)\n    ON CONFLICT (user_id, course_id) WHERE deleted_at IS NULL\n    DO UPDATE SET\n      total_duration_seconds = EXCLUDED.total_duration_seconds,\n      total_points = EXCLUDED.total_points\n    RETURNING *\n      ",
