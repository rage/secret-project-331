  "query": "\nSELECT COUNT(DISTINCT c.id) AS \"chapters!\",\n  COUNT(e.id) AS \"exercises!\"\nFROM chapters c\n  LEFT JOIN exercises e ON e.chapter_id = c.id\n  AND e.deleted_at IS NULL\nWHERE c.course_module_id = $1\n  AND c.deleted_at IS NULL\n        ",
