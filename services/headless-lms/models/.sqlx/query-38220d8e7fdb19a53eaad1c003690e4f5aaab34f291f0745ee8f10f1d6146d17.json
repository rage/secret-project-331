  "query": "\nSELECT\n  m.id,\n  m.user_id,\n  ud.first_name,\n  ud.last_name,\n  ud.email,\n  m.created_at\nFROM course_designer_plan_members m\nJOIN user_details ud ON ud.user_id = m.user_id\nWHERE m.course_designer_plan_id = $1\n  AND m.deleted_at IS NULL\nORDER BY m.created_at ASC, m.id ASC\n",
