  "db_name": "PostgreSQL",
  "query": "\nSELECT\n  p.id,\n  p.created_at,\n  p.updated_at,\n  p.deleted_at,\n  p.created_by_user_id,\n  p.name,\n  p.status,\n  p.active_stage,\n  p.last_weekly_stage_email_sent_at\nFROM course_designer_plans p\nJOIN course_designer_plan_members m\n  ON m.course_designer_plan_id = p.id\n  AND m.user_id = $2\n  AND m.deleted_at IS NULL\nWHERE p.id = $1\n  AND p.deleted_at IS NULL\n",
