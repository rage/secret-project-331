{
  "db_name": "PostgreSQL",
  "query": "\nSELECT p.url_path as url_path,\n  p.title as title,\n  c.chapter_number as chapter_number,\n  p.id as page_id,\n  c.id as chapter_id,\n  c.opens_at as chapter_opens_at,\n  c.front_page_id as chapter_front_page_id\nFROM pages p\n  LEFT JOIN chapters c ON p.chapter_id = c.id\nWHERE p.order_number = (\n    SELECT MAX(pa.order_number)\n    FROM pages pa\n    WHERE pa.order_number < $1\n      AND pa.deleted_at IS NULL\n      AND pa.hidden IS DISTINCT FROM $4\n      AND pa.course_id = p.course_id\n      AND pa.chapter_id IS NOT DISTINCT FROM p.chapter_id\n  )\n  AND p.course_id = $2\n  AND c.chapter_number = $3\n  AND p.deleted_at IS NULL\n  AND p.hidden IS DISTINCT FROM $4;\n        ",
