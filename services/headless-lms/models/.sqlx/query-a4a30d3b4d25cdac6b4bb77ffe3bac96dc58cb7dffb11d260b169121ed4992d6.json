{
  "db_name": "PostgreSQL",
  "query": "\nSELECT exams.id,\n  exams.created_at,\n  exams.updated_at,\n  exams.deleted_at,\n  exams.organization_id,\n  exams.name,\n  exams.instructions,\n  pages.id AS page_id,\n  exams.starts_at,\n  exams.ends_at,\n  exams.time_minutes,\n  exams.minimum_points_treshold,\n  COALESCE(exams.language, 'en-US') AS \"language!\",\n  exams.grade_manually\nFROM exams\n  JOIN pages ON pages.exam_id = exams.id\nWHERE exams.id = $1\n  AND exams.deleted_at IS NULL\n  AND pages.deleted_at IS NULL\n        ",
