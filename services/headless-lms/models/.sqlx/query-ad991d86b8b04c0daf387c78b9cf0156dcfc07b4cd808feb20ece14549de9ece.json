{
  "db_name": "PostgreSQL",
  "query": "\nINSERT INTO page_visit_datum_summary_by_courses_countries (\n    course_id,\n    exam_id,\n    country,\n    num_visitors,\n    visit_date\n  )\nSELECT course_id,\n  exam_id,\n  country,\n  COUNT(DISTINCT anonymous_identifier) AS num_visitors,\n  $1 AS visit_date\nFROM page_visit_datum\nWHERE deleted_at IS NULL\n  AND created_at >= ($1::date::timestamp AT TIME ZONE 'UTC')\n  AND created_at < (($1::date + 1)::timestamp AT TIME ZONE 'UTC')\n  AND is_bot = FALSE\nGROUP BY course_id,\n  exam_id,\n  country ON CONFLICT (\n    course_id,\n    exam_id,\n    visit_date,\n    country,\n    deleted_at\n  ) DO\nUPDATE\nSET num_visitors = EXCLUDED.num_visitors\nRETURNING *;\n",
