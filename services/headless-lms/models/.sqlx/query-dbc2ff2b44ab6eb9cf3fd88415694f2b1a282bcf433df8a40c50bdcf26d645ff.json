  "query": "\nSELECT\n  id,\n  created_at,\n  updated_at,\n  stage,\n  status,\n  planned_starts_on,\n  planned_ends_on,\n  actual_started_at,\n  actual_completed_at,\n  workspace_data\nFROM course_designer_plan_stages\nWHERE course_designer_plan_id = $1\n  AND deleted_at IS NULL\nORDER BY\n  CASE stage\n    WHEN 'analysis' THEN 1\n    WHEN 'design' THEN 2\n    WHEN 'development' THEN 3\n    WHEN 'implementation' THEN 4\n    WHEN 'evaluation' THEN 5\n  END,\n  id\n",
