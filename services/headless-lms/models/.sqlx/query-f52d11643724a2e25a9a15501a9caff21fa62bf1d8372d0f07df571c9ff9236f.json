{
  "db_name": "PostgreSQL",
  "query": "\nINSERT INTO chatbot_conversation_messages (\n    conversation_id,\n    order_number\n)\nVALUES (\n    $1,\n    COALESCE((\n      SELECT order_number\n      FROM chatbot_conversation_messages\n      WHERE conversation_id = $1\n        AND deleted_at IS NULL\n      ORDER BY order_number DESC\n      LIMIT 1\n    ), 0) + 1\n)\nRETURNING *\n        ",
