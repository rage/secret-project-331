  "repository": {
    "type": "git",
    "url": "git+https://github.com/rage/secret-project-331.git",
    "directory": "shared-module/packages/create-exercise-service"
  },
  "bin": {
    "create-exercise-service": "./dist/index.mjs"
  },
  "files": [
