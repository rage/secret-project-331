{
  "name": "@moocfi/exercise-protocol",
  "version": "0.0.0",
  "description": "The moocfi exercise-service contract: parent<->iframe postMessage protocol types, runtime guards, and shared constants. Zero dependencies, framework-agnostic.",
  "keywords": [
    "exercise-service",
    "moocfi",
    "protocol"
  ],
  "homepage": "https://github.com/rage/secret-project-331#readme",
  "license": "Apache-2.0",
  "author": "Henrik Nygren <nygrenh@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rage/secret-project-331.git",
    "directory": "shared-module/packages/exercise-protocol"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "generate-guards": "pnpm exec ts-auto-guard --export-all --paths src/core/exercise-service-protocol-types.ts --project tsconfig.guards.json && sed -i -E 's/^import \\{/import type {/' src/core/exercise-service-protocol-types.guard.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@types/node": "^26.0.1",
    "@typescript/native": "npm:typescript@^7.0.2",
    "publint": "0.3.21",
    "ts-auto-guard": "^5.1.3",
    "tsdown": "0.22.7",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "download",
      "version": "24.18.0"
    }
  }
}
