{
  "name": "@moocfi/exercise-react",
  "version": "0.0.0",
  "description": "React adapter for moocfi exercise services: hooks, contexts, components, i18n, and styles wrapping the framework-agnostic @moocfi/exercise-client engines.",
  "keywords": [
    "exercise-service",
    "iframe",
    "moocfi",
    "react"
  ],
  "homepage": "https://github.com/rage/secret-project-331#readme",
  "license": "Apache-2.0",
  "author": "Henrik Nygren <nygrenh@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rage/secret-project-331.git",
    "directory": "shared-module/packages/exercise-react"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/GlobalStyles.js"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "default": "./dist/*.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules\" jest"
  },
  "dependencies": {
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "i18next": "^26.3.0",
    "immer": "^11.1.8",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "msw": "^2.14.6",
    "next": "^16.2.6",
    "publint": "0.3.21",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "tsdown": "0.22.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "i18next": ">=23.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.0.0 || ^16.0.0 || ^17.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "download",
      "version": "24.18.0"
    }
  }
}
